# ============================================
# 数据库配置
# ============================================
DATABASE_URL="mysql://root:root123@localhost:3306/mao_memorial"

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ============================================
# JWT 配置
# ============================================
# 生产环境必须修改：请生成 32+ 字符随机字符串
# 示例命令：openssl rand -hex 32
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info

# ============================================
# 预留：生产环境部署配置
# ============================================
# MYSQL_ROOT_PASSWORD=root123
# MYSQL_DATABASE=mao_memorial
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
