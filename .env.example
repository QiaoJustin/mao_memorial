# ============================================
# 应用配置
# ============================================
NODE_ENV=development
APP_NAME=毛主席生平纪念网站
APP_URL=http://localhost:3000
APP_PORT=3000

# ============================================
# 数据库配置（Docker Compose 启动后使用 root/root123）
# ============================================
DATABASE_URL="mysql://root:root123@localhost:3306/mao_memorial"
SHADOW_DATABASE_URL="mysql://root:root123@localhost:3306/mao_memorial_shadow"

# ============================================
# Redis 配置
# ============================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ============================================
# JWT 配置
# ============================================
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ============================================
# 文件上传配置
# ============================================
UPLOAD_DIR="./uploads"
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,image/webp"

# ============================================
# OSS 配置（可选，生产环境推荐）
# ============================================
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET=""
OSS_REGION="oss-cn-beijing"
OSS_ENDPOINT=""

# ============================================
# CDN 配置
# ============================================
CDN_BASE_URL=""

# ============================================
# 日志配置
# ============================================
LOG_LEVEL="info"
LOG_DIR="./logs"

# ============================================
# 安全配置
# ============================================
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN="http://localhost:3000"

# ============================================
# 数据来源（仅供说明，非运行时变量）
# ============================================
DATA_SOURCE_URL="https://www.12371.cn/2021/12/26/ARTI1640485049308845.shtml"
